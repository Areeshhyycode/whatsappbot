# Copy this file to ".env" and fill in your own values.
# The real ".env" file is git-ignored so your secrets stay private.

# Groq AI API key (free) — get one at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google API key for embeddings (free) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# MongoDB connection string — get one free at https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/whatsappbot

# Secret used to sign login tokens — put any long random string here.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# --- WhatsApp bot worker (optional, whatsapp-web.js) ---
BOT_ID=
REQUIRE_PREFIX=false
BOT_PREFIX=!

# --- WhatsApp Cloud API (optional, official Meta API) ---
WHATSAPP_VERIFY_TOKEN=any_string_you_choose
WHATSAPP_TOKEN=your_meta_access_token
